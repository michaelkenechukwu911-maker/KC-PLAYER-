<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
<title>KC-Player</title>
<link rel="manifest" href="manifest.json">
<link rel="icon" type="image/png" sizes="192x192" href="data:image/png;base64,">
<link rel="apple-touch-icon" href="data:image/png;base64,">
<meta name="theme-color" content="#0A0B0D">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
<meta name="apple-mobile-web-app-title" content="KC-Player">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@500;700&display=swap" rel="stylesheet">
<style>
  :root{
    --bg: #0A0B0D;
    --panel: #15171B;
    --panel-raised: #1D2025;
    --line: #262A31;
    --text: #F2F3F5;
    --muted: #868C97;
    --tally: #FF4B4B;
    --amber: #FFB020;
    --amber-dim: #4d3a14;
  }
  *{box-sizing:border-box; -webkit-tap-highlight-color:transparent;}
  html,body{height:100%;}
  body{
    margin:0; background:var(--bg); color:var(--text);
    font-family:'Inter',system-ui,sans-serif;
    overflow:hidden; overscroll-behavior:none;
    display:flex; justify-content:center;
  }
  #phone{
    width:100%; max-width:430px; height:100vh; max-height:920px;
    position:relative; background:#000; overflow:hidden;
    border-left:1px solid var(--line); border-right:1px solid var(--line);
  }
  .mono{ font-family:'JetBrains Mono',monospace; }
  .display{ font-family:'Bebas Neue',sans-serif; letter-spacing:0.04em; }

  /* ---------- screens ---------- */
  .screen{ position:absolute; inset:0; display:none; flex-direction:column; }
  .screen.active{ display:flex; }

  /* ---------- watch screen ---------- */
  #watchScreen{ background:var(--bg); }
  #playerStage{
    flex:1; display:flex; align-items:center; justify-content:center;
    background:var(--bg); overflow:hidden; min-height:0;
  }
  #videoWrap{
    position:relative; width:100%; aspect-ratio:16/9; background:#000;
    overflow:hidden; display:flex; align-items:center; justify-content:center;
    flex-shrink:0; max-height:100%;
  }
  #sourceVideo{ width:100%; height:100%; object-fit:contain; display:block; background:#000; }

  /* Landscape: expand the player to fill the whole viewport, immersive-player style */
  #phone.landscape-player{ max-width:100vw; max-height:100vh; border:none; }
  #phone.landscape-player #videoWrap{
    position:fixed; inset:0; aspect-ratio:auto; width:100vw; height:100vh; max-height:none; z-index:50;
  }
  #phone.landscape-player .tabbar{ display:none; }
  #phone.landscape-player .now-playing{ bottom:70px; }

  .hud-top{
    position:absolute; top:0; left:0; right:0;
    padding:16px 16px 0; display:flex; justify-content:space-between; align-items:flex-start;
    z-index:5; background:linear-gradient(180deg, rgba(0,0,0,0.55), rgba(0,0,0,0));
    pointer-events:none;
  }
  .hud-top > *{ pointer-events:auto; }
  .brand{ display:flex; align-items:center; gap:8px; padding-top:6px; }
  .brand-dot{ width:8px; height:8px; border-radius:50%; background:var(--tally); }
  .brand-name{ font-size:20px; letter-spacing:0.06em; }

  #libraryScreen{ background:var(--bg); }
  .lib-header{ padding:18px 18px 12px; border-bottom:1px solid var(--line); }
  .lib-header h1{ font-size:26px; margin:0 0 2px; }
  .lib-header p{ margin:0; color:var(--muted); font-size:12px; }
  .lib-grid{ flex:1; overflow-y:auto; padding:16px; display:grid; grid-template-columns:1fr 1fr; gap:12px; align-content:start; }
  .lib-card{ background:var(--panel); border:1px solid var(--line); border-radius:12px; overflow:hidden; cursor:pointer; }
  .lib-card.playing{ border-color:var(--amber); }
  .lib-thumb-wrap{ position:relative; width:100%; aspect-ratio:9/16; background:#000; }
  .lib-thumb{ width:100%; height:100%; object-fit:cover; display:block; }
  .lib-duration{
    position:absolute; right:6px; bottom:6px; background:rgba(0,0,0,0.75);
    color:#fff; font-family:'JetBrains Mono',monospace; font-size:10px;
    padding:2px 6px; border-radius:4px; letter-spacing:0.02em;
  }
  .lib-name{
    padding:9px 10px 10px; font-size:12.5px; font-weight:600; color:var(--text);
    line-height:1.3; display:-webkit-box; -webkit-line-clamp:2; -webkit-box-orient:vertical;
    overflow:hidden;
  }
  .lib-add-card{
    aspect-ratio:9/16; border:1.5px dashed var(--line); border-radius:12px;
    display:flex; flex-direction:column; align-items:center; justify-content:center;
    gap:6px; color:var(--muted); font-size:12px; cursor:pointer;
  }
  .lib-add-card .plus{ font-size:26px; color:var(--amber); }
  .lib-empty{ grid-column:1/-1; text-align:center; color:var(--muted); padding:60px 20px; font-size:13px; }

  #permissionGate{
    flex:1; display:flex; flex-direction:column; align-items:center; justify-content:center;
    text-align:center; padding:32px 28px; gap:16px;
  }
  #permissionGate .perm-icon{
    width:64px; height:64px; border-radius:16px; background:var(--panel-raised);
    border:1px solid var(--line); display:flex; align-items:center; justify-content:center;
    font-size:28px; margin-bottom:4px;
  }
  #permissionGate h2{ font-size:19px; margin:0; }
  #permissionGate p{ color:var(--muted); font-size:13px; line-height:1.5; margin:0; max-width:280px; }
  #permissionGate .btn-primary{ padding:12px 28px; font-size:13.5px; margin-top:6px; }
  #permissionGate .perm-denied{ color:var(--tally); font-size:12px; display:none; }
  #permissionGate .perm-denied.show{ display:block; }
  #permissionGate .perm-scanning{ display:none; align-items:center; gap:8px; color:var(--muted); font-size:12.5px; }
  #permissionGate .perm-scanning.show{ display:flex; }
  .spin{ width:14px; height:14px; border-radius:50%; border:2px solid var(--line); border-top-color:var(--amber); animation:spin 0.8s linear infinite; }
  @keyframes spin{ to{ transform:rotate(360deg); } }

  #libGrid{ display:none; }
  #libGrid.granted{ display:grid; }

  #backToLibraryBtn{
    width:40px; height:40px; border-radius:10px; margin-top:2px;
    background:rgba(20,20,22,0.55); border:1px solid rgba(255,255,255,0.25);
    color:#fff; font-size:16px; cursor:pointer; backdrop-filter:blur(6px);
    display:flex; align-items:center; justify-content:center;
  }
  .now-playing{
    position:absolute; left:16px; bottom:78px; z-index:5;
    background:rgba(20,20,22,0.6); backdrop-filter:blur(6px);
    border:1px solid rgba(255,255,255,0.15); border-radius:8px;
    padding:6px 10px; font-size:11px; color:var(--muted); max-width:70%;
    overflow:hidden; text-overflow:ellipsis; white-space:nowrap;
  }

  .transport{
    position:absolute; left:0; right:0; bottom:0; z-index:5;
    background:linear-gradient(0deg, rgba(0,0,0,0.75), rgba(0,0,0,0));
    padding:28px 16px 12px;
  }
  .transport-scrub{ display:flex; align-items:center; gap:8px; margin-bottom:10px; }
  .transport-scrub input[type=range]{ flex:1; accent-color:var(--amber); height:3px; }
  .transport-time{ font-family:'JetBrains Mono',monospace; font-size:10.5px; color:var(--muted); min-width:36px; text-align:center; }
  .transport-buttons{ display:flex; align-items:center; justify-content:center; gap:28px; }
  .transport-btn{
    background:none; border:none; color:#fff; cursor:pointer;
    display:flex; align-items:center; justify-content:center;
    width:40px; height:40px; font-size:22px; padding:0;
  }
  .transport-btn.skip{ font-size:13px; flex-direction:column; gap:1px; }
  .transport-btn.skip .skip-amt{ font-family:'JetBrains Mono',monospace; font-size:9px; color:var(--muted); }
  #playPauseBtn{
    width:52px; height:52px; border-radius:50%; background:rgba(255,255,255,0.12);
    border:1px solid rgba(255,255,255,0.25); font-size:20px;
  }

  #recordBtn{
    width:56px; height:56px; border-radius:50%;
    background:rgba(20,20,22,0.55); border:2px solid rgba(255,255,255,0.85);
    display:flex; align-items:center; justify-content:center;
    cursor:pointer; backdrop-filter:blur(6px);
    transition:transform .15s ease;
  }
  #recordBtn:active{ transform:scale(0.92); }
  #recordBtn .dot{ width:26px; height:26px; border-radius:50%; background:var(--tally); transition:.2s; }
  #recordBtn.recording .dot{ border-radius:6px; width:20px; height:20px; }

  #recIndicator{
    display:none; align-items:center; gap:8px;
    background:rgba(20,20,22,0.7); backdrop-filter:blur(6px);
    padding:8px 12px; border-radius:20px; border:1px solid rgba(255,75,75,0.5);
  }
  #recIndicator.live{ display:flex; }
  .tally-blink{ width:9px; height:9px; border-radius:50%; background:var(--tally); animation:blink 1s infinite; }
  @keyframes blink{ 50%{ opacity:0.15; } }
  #timecode{ font-size:13px; letter-spacing:0.03em; }

  #toast{
    position:absolute; bottom:96px; left:50%; transform:translateX(-50%) translateY(20px);
    background:var(--panel-raised); border:1px solid var(--line); color:var(--text);
    padding:10px 18px; border-radius:10px; font-size:13px; opacity:0; pointer-events:none;
    transition:.25s ease; z-index:20; white-space:nowrap;
  }
  #toast.show{ opacity:1; transform:translateX(-50%) translateY(0); }

  .tabbar{
    display:flex; background:var(--panel); border-top:1px solid var(--line);
    padding:10px 10px calc(10px + env(safe-area-inset-bottom));
  }
  .tab{
    flex:1; text-align:center; background:none; border:none; color:var(--muted);
    font-family:'Inter',sans-serif; font-size:12px; font-weight:600; letter-spacing:0.03em;
    padding:8px 0; cursor:pointer; display:flex; flex-direction:column; align-items:center; gap:4px;
  }
  .tab.active{ color:var(--amber); }
  .tab .icon{ font-size:18px; }
  .badge{
    background:var(--tally); color:#fff; font-size:10px; border-radius:10px;
    padding:1px 6px; margin-left:4px; font-family:'JetBrains Mono',monospace;
  }

  /* ---------- clips screen ---------- */
  #clipsScreen{ background:var(--bg); }
  .header{
    padding:18px 18px 10px; border-bottom:1px solid var(--line);
    display:flex; align-items:baseline; justify-content:space-between;
  }
  .header h1{ font-size:26px; margin:0; }
  .header p{ margin:2px 0 0; color:var(--muted); font-size:12px; }

  #clipGrid{
    flex:1; overflow-y:auto; padding:16px; display:grid;
    grid-template-columns:1fr 1fr; gap:12px; align-content:start;
  }
  .empty-state{
    grid-column:1/-1; text-align:center; color:var(--muted); padding:60px 20px; font-size:13px;
  }
  .clip-card{
    background:var(--panel); border:1px solid var(--line); border-radius:12px; overflow:hidden;
    cursor:pointer; position:relative;
  }
  .clip-thumb{ width:100%; aspect-ratio:9/16; object-fit:cover; background:#000; display:block; }
  .clip-meta{ padding:8px 10px; }
  .clip-meta .dur{ font-family:'JetBrains Mono',monospace; font-size:11px; color:var(--amber); }
  .clip-del{
    position:absolute; top:6px; right:6px; width:26px; height:26px; border-radius:50%;
    background:rgba(0,0,0,0.6); border:1px solid rgba(255,255,255,0.2); color:#fff;
    display:flex; align-items:center; justify-content:center; font-size:13px; cursor:pointer;
  }

  /* ---------- editor ---------- */
  #editorPane{ position:absolute; inset:0; background:var(--bg); display:none; flex-direction:column; z-index:30; }
  #editorPane.active{ display:flex; }
  .editor-top{
    display:flex; align-items:center; gap:10px; padding:14px 16px; border-bottom:1px solid var(--line);
  }
  .icon-btn{
    background:var(--panel-raised); border:1px solid var(--line); color:var(--text);
    width:34px; height:34px; border-radius:8px; cursor:pointer; font-size:15px;
  }
  .editor-top .title{ flex:1; font-size:14px; font-weight:600; }
  .btn-primary{
    background:var(--amber); color:#1a1200; border:none; font-weight:700; font-size:12.5px;
    padding:9px 16px; border-radius:8px; cursor:pointer; letter-spacing:0.02em;
  }
  .btn-primary:disabled{ opacity:0.5; }

  #canvasStage{
    flex:1; display:flex; align-items:center; justify-content:center; background:#050506;
    position:relative; overflow:hidden;
  }
  #editCanvas{ max-width:100%; max-height:100%; touch-action:none; border-radius:4px; }
  #exportProgress{
    position:absolute; inset:0; background:rgba(5,5,6,0.85); display:none;
    flex-direction:column; align-items:center; justify-content:center; gap:10px; z-index:5;
  }
  #exportProgress.active{ display:flex; }
  .prog-track{ width:70%; height:4px; background:var(--line); border-radius:2px; overflow:hidden; }
  .prog-fill{ height:100%; width:0%; background:var(--amber); transition:width .1s linear; }

  .editor-controls{ background:var(--panel); border-top:1px solid var(--line); padding:14px 16px calc(14px + env(safe-area-inset-bottom)); }
  .control-tabs{ display:flex; gap:6px; margin-bottom:14px; }
  .ctrl-tab{
    flex:1; background:var(--panel-raised); border:1px solid var(--line); color:var(--muted);
    padding:8px 4px; border-radius:8px; font-size:11px; font-weight:600; cursor:pointer;
  }
  .ctrl-tab.active{ color:var(--amber); border-color:var(--amber); background:var(--amber-dim); }
  .ctrl-panel{ display:none; }
  .ctrl-panel.active{ display:block; }

  .chip-row{ display:flex; gap:8px; flex-wrap:wrap; }
  .chip{
    background:var(--panel-raised); border:1px solid var(--line); color:var(--text);
    padding:7px 14px; border-radius:20px; font-size:12px; cursor:pointer;
  }
  .chip.active{ border-color:var(--amber); color:var(--amber); }

  .slider-row{ display:flex; align-items:center; gap:10px; margin-top:2px; }
  .slider-row label{ font-size:11px; color:var(--muted); width:44px; }
  input[type=range]{ flex:1; accent-color:var(--amber); }

  .text-add-row{ display:flex; gap:8px; margin-bottom:10px; }
  .text-add-row input{
    flex:1; background:var(--panel-raised); border:1px solid var(--line); color:var(--text);
    padding:9px 12px; border-radius:8px; font-size:13px;
  }
  .text-add-row button{
    background:var(--amber); border:none; color:#1a1200; font-weight:700; padding:0 14px; border-radius:8px; cursor:pointer;
  }
  .text-layer-item{
    display:flex; align-items:center; justify-content:space-between;
    background:var(--panel-raised); border:1px solid var(--line); border-radius:8px;
    padding:8px 10px; margin-bottom:6px; font-size:12px;
  }
  .text-layer-item span{ color:var(--muted); font-size:10px; margin-left:6px; }
  .text-layer-item button{ background:none; border:none; color:var(--tally); cursor:pointer; font-size:14px; }
  .hint{ font-size:11px; color:var(--muted); margin-top:6px; }

  #downloadRow{ display:none; margin-top:10px; }
  #downloadRow.active{ display:flex; }
  #downloadLink{
    flex:1; text-align:center; background:var(--tally); color:#fff; text-decoration:none;
    padding:11px; border-radius:8px; font-weight:700; font-size:13px;
  }
</style>
</head>
<body>
<div id="phone">

  <!-- ============ LIBRARY (home screen) ============ -->
  <div id="libraryScreen" class="screen active">
    <div class="lib-header" style="display:flex; align-items:flex-start; justify-content:space-between;">
      <div>
        <h1 class="display">YOUR VIDEOS</h1>
        <p id="libSubtitle">Access not yet granted</p>
      </div>
      <button class="icon-btn" id="addLocationBtn" title="Add another storage location (e.g. SD card)" style="display:none; flex-shrink:0;">+</button>
    </div>

    <input type="file" id="fileInput" accept="video/*" webkitdirectory multiple style="display:none;">

    <div id="permissionGate">
      <div class="perm-icon">🎞</div>
      <h2>Allow access to your videos</h2>
      <p>KC-Player needs permission to see the videos stored on your device so it can list them here — nothing is uploaded anywhere.</p>
      <button class="btn-primary" id="grantAccessBtn">Allow access</button>
      <div class="perm-scanning" id="permScanning"><div class="spin"></div>Scanning your videos…</div>
      <div class="perm-denied" id="permDenied">No videos were found in the selected location, or access was cancelled. <span style="color:var(--amber); cursor:pointer;" id="retryPermBtn">Try again</span></div>
    </div>

    <div class="lib-grid" id="libGrid"></div>

    <div class="tabbar">
      <button class="tab active" data-tab="library"><span class="icon">🎞</span>Library</button>
      <button class="tab" data-tab="clips"><span class="icon">✂</span>Clips<span class="badge" id="clipCount2">0</span></button>
    </div>
  </div>

  <!-- ============ WATCH ============ -->
  <div id="watchScreen" class="screen">
    <div id="playerStage">
    <div id="videoWrap">
      <video id="sourceVideo" playsinline></video>
      <canvas id="captureCanvas" style="position:absolute; top:0; left:-99999px;"></canvas>

      <div class="hud-top">
        <button id="backToLibraryBtn" title="Back to your videos">←</button>
        <div style="display:flex; align-items:center; gap:10px;">
          <div id="recIndicator" class="mono">
            <div class="tally-blink"></div>
            <div id="timecode">00:00</div>
          </div>
          <button id="recordBtn" title="Capture this moment"><div class="dot"></div></button>
        </div>
      </div>

      <div class="now-playing" id="nowPlaying"></div>

      <div class="transport">
        <div class="transport-scrub">
          <div class="transport-time" id="curTime">0:00</div>
          <input type="range" id="scrubBar" min="0" max="100" step="0.1" value="0">
          <div class="transport-time" id="durTime">0:00</div>
        </div>
        <div class="transport-buttons">
          <button class="transport-btn skip" id="rewindBtn" title="Back 10s">⏪<span class="skip-amt">10s</span></button>
          <button class="transport-btn" id="playPauseBtn" title="Play/Pause">▶</button>
          <button class="transport-btn skip" id="forwardBtn" title="Forward 10s">⏩<span class="skip-amt">10s</span></button>
        </div>
      </div>

      <div id="toast"></div>
    </div>
    </div>

    <div class="tabbar">
      <button class="tab" data-tab="library"><span class="icon">🎞</span>Library</button>
      <button class="tab" data-tab="clips"><span class="icon">✂</span>Clips<span class="badge" id="clipCount">0</span></button>
    </div>
  </div>


  <!-- ============ CLIPS LIBRARY ============ -->
  <div id="clipsScreen" class="screen">
    <div class="header">
      <div>
        <h1 class="display">CLIPS</h1>
        <p>Moments you've captured, ready to edit</p>
      </div>
    </div>
    <div id="clipGrid">
      <div class="empty-state">No clips yet — tap the record button while watching to save a moment.</div>
    </div>
    <div class="tabbar">
      <button class="tab" data-tab="library"><span class="icon">🎞</span>Library</button>
      <button class="tab active" data-tab="clips"><span class="icon">✂</span>Clips<span class="badge" id="clipCount2b">0</span></button>
    </div>
  </div>

  <!-- ============ EDITOR ============ -->
  <div id="editorPane">
    <div class="editor-top">
      <button class="icon-btn" id="closeEditor">←</button>
      <div class="title">Edit clip</div>
      <button class="btn-primary" id="exportBtn">Export</button>
    </div>

    <div id="canvasStage">
      <canvas id="editCanvas"></canvas>
      <video id="editVideo" style="position:absolute; top:0; left:-99999px; width:1px; height:1px;" playsinline crossorigin="anonymous"></video>
      <div id="exportProgress">
        <div class="mono" id="exportLabel" style="font-size:12px; color:var(--muted);">Rendering export…</div>
        <div class="prog-track"><div class="prog-fill" id="progFill"></div></div>
      </div>
    </div>

    <div class="editor-controls">
      <div class="control-tabs">
        <button class="ctrl-tab active" data-ctrl="ratio">Ratio</button>
        <button class="ctrl-tab" data-ctrl="zoom">Zoom</button>
        <button class="ctrl-tab" data-ctrl="text">Text</button>
        <button class="ctrl-tab" data-ctrl="fx">Effects</button>
      </div>

      <div class="ctrl-panel active" data-panel="ratio">
        <div class="chip-row">
          <div class="chip active" data-ratio="original">Original</div>
          <div class="chip" data-ratio="9:16">9:16</div>
          <div class="chip" data-ratio="1:1">1:1</div>
          <div class="chip" data-ratio="16:9">16:9</div>
        </div>
      </div>

      <div class="ctrl-panel" data-panel="zoom">
        <div class="slider-row">
          <label>Zoom</label>
          <input type="range" id="zoomSlider" min="1" max="3" step="0.01" value="1">
        </div>
        <div class="hint">Drag directly on the frame above to pan once zoomed in.</div>
      </div>

      <div class="ctrl-panel" data-panel="text">
        <div class="text-add-row">
          <input type="text" id="textInput" placeholder="Add a caption…" maxlength="40">
          <button id="addTextBtn">Add</button>
        </div>
        <div id="textLayerList"></div>
        <div class="hint">Drag captions on the frame to reposition.</div>
      </div>

      <div class="ctrl-panel" data-panel="fx">
        <div class="chip-row">
          <div class="chip active" data-fx="none">None</div>
          <div class="chip" data-fx="mono">Mono</div>
          <div class="chip" data-fx="warm">Warm</div>
          <div class="chip" data-fx="noir">Noir</div>
        </div>
        <div class="slider-row" style="margin-top:12px;">
          <label>Vignette</label>
          <input type="range" id="vignetteSlider" min="0" max="1" step="0.05" value="0">
        </div>
      </div>

      <div id="downloadRow">
        <button id="saveShareBtn" class="btn-primary" style="flex:1; padding:11px;">Save clip</button>
        <a id="downloadLink" href="#" download="kc-player-clip.webm" style="display:none;">Download exported clip</a>
      </div>
    </div>
  </div>

</div>

<script>
(function(){
  const sourceVideo = document.getElementById('sourceVideo');
  const captureCanvas = document.getElementById('captureCanvas');
  const recordBtn = document.getElementById('recordBtn');
  const recIndicator = document.getElementById('recIndicator');
  const timecodeEl = document.getElementById('timecode');
  const toastEl = document.getElementById('toast');

  let clips = [];
  let mediaRecorder, recordedChunks, captureCtx, rafCapture, recordStartTs;
  let isRecording = false;

  function toast(msg){
    toastEl.textContent = msg;
    toastEl.classList.add('show');
    clearTimeout(toast._t);
    toast._t = setTimeout(()=> toastEl.classList.remove('show'), 2200);
  }

  function fmtTime(sec){
    const m = Math.floor(sec/60).toString().padStart(2,'0');
    const s = Math.floor(sec%60).toString().padStart(2,'0');
    return m+':'+s;
  }

  // ---------- TRANSPORT CONTROLS (play/pause, skip, scrub) ----------
  const playPauseBtn = document.getElementById('playPauseBtn');
  const rewindBtn = document.getElementById('rewindBtn');
  const forwardBtn = document.getElementById('forwardBtn');
  const scrubBar = document.getElementById('scrubBar');
  const curTimeEl = document.getElementById('curTime');
  const durTimeEl = document.getElementById('durTime');
  let userScrubbing = false;

  playPauseBtn.addEventListener('click', () => {
    if (sourceVideo.paused) sourceVideo.play().catch(()=>{});
    else sourceVideo.pause();
  });
  sourceVideo.addEventListener('play', () => { playPauseBtn.textContent = '⏸'; });
  sourceVideo.addEventListener('pause', () => { playPauseBtn.textContent = '▶'; });

  rewindBtn.addEventListener('click', () => {
    sourceVideo.currentTime = Math.max(0, sourceVideo.currentTime - 10);
  });
  forwardBtn.addEventListener('click', () => {
    const dur = sourceVideo.duration || Infinity;
    sourceVideo.currentTime = Math.min(dur, sourceVideo.currentTime + 10);
  });

  sourceVideo.addEventListener('loadedmetadata', () => {
    scrubBar.max = sourceVideo.duration || 0;
    durTimeEl.textContent = fmtTime(sourceVideo.duration || 0);
  });
  sourceVideo.addEventListener('timeupdate', () => {
    if (userScrubbing) return;
    scrubBar.value = sourceVideo.currentTime;
    curTimeEl.textContent = fmtTime(sourceVideo.currentTime);
  });
  scrubBar.addEventListener('input', () => {
    userScrubbing = true;
    curTimeEl.textContent = fmtTime(parseFloat(scrubBar.value));
  });
  scrubBar.addEventListener('change', () => {
    sourceVideo.currentTime = parseFloat(scrubBar.value);
    userScrubbing = false;
  });

  // ---------- CAPTURE (record while watching, playback never pauses) ----------
  function startCapture(){
    if (!sourceVideo.videoWidth) { toast('Video still loading — try again in a second'); return; }
    captureCanvas.width = sourceVideo.videoWidth;
    captureCanvas.height = sourceVideo.videoHeight;
    captureCtx = captureCanvas.getContext('2d');

    const canvasStream = captureCanvas.captureStream(30);
    try {
      const liveStream = sourceVideo.captureStream ? sourceVideo.captureStream() : sourceVideo.mozCaptureStream();
      liveStream.getAudioTracks().forEach(t => canvasStream.addTrack(t));
    } catch(e){ console.warn('Audio capture unavailable in this browser', e); }

    let mimeType = 'video/webm;codecs=vp9,opus';
    if (!MediaRecorder.isTypeSupported(mimeType)) mimeType = 'video/webm';

    mediaRecorder = new MediaRecorder(canvasStream, { mimeType });
    recordedChunks = [];
    mediaRecorder.ondataavailable = e => { if (e.data.size > 0) recordedChunks.push(e.data); };
    mediaRecorder.onstop = finalizeClip;
    mediaRecorder.start();

    recordStartTs = performance.now();
    isRecording = true;
    recordBtn.classList.add('recording');
    recIndicator.classList.add('live');
    drawCaptureLoop();
  }

  function drawCaptureLoop(){
    if (!isRecording) return;
    captureCtx.drawImage(sourceVideo, 0, 0, captureCanvas.width, captureCanvas.height);
    timecodeEl.textContent = fmtTime((performance.now() - recordStartTs) / 1000);
    rafCapture = requestAnimationFrame(drawCaptureLoop);
  }

  function stopCapture(){
    isRecording = false;
    cancelAnimationFrame(rafCapture);
    recordBtn.classList.remove('recording');
    recIndicator.classList.remove('live');
    mediaRecorder.stop();
  }

  function finalizeClip(){
    const blob = new Blob(recordedChunks, { type: 'video/webm' });
    const url = URL.createObjectURL(blob);
    const clip = {
      id: 'clip_' + Date.now(),
      url, blob,
      duration: (performance.now() - recordStartTs) / 1000,
      thumb: captureCanvas.toDataURL('image/jpeg', 0.65)
    };
    clips.unshift(clip);
    renderClipGrid();
    toast('Clip saved — playback never stopped');
  }

  recordBtn.addEventListener('click', () => { isRecording ? stopCapture() : startCapture(); });

  // ---------- LOCAL VIDEO LIBRARY (home screen) ----------
  // Stand-in for native gallery access: on Android this would query MediaStore.Video
  // (with READ_MEDIA_VIDEO on API 33+), on iOS the Photos framework via PHPickerViewController.
  // In the browser, the file picker is the closest equivalent — it surfaces the device's
  // own video files without the app needing broad filesystem access.
  const fileInput = document.getElementById('fileInput');
  const libGrid = document.getElementById('libGrid');
  const libSubtitle = document.getElementById('libSubtitle');
  const nowPlaying = document.getElementById('nowPlaying');
  const backToLibraryBtn = document.getElementById('backToLibraryBtn');
  let library = []; // { id, file, url, name, thumb, status }
  let activeLibraryId = null;

  const grantAccessBtn = document.getElementById('grantAccessBtn');
  const retryPermBtn = document.getElementById('retryPermBtn');
  const addLocationBtn = document.getElementById('addLocationBtn');
  const permissionGate = document.getElementById('permissionGate');
  const permScanning = document.getElementById('permScanning');
  const permDenied = document.getElementById('permDenied');
  let accessGranted = false;
  const seenKeys = new Set(); // dedupe across multiple granted locations

  grantAccessBtn.addEventListener('click', () => { permDenied.classList.remove('show'); fileInput.click(); });
  retryPermBtn.addEventListener('click', () => { permDenied.classList.remove('show'); fileInput.click(); });
  addLocationBtn.addEventListener('click', () => fileInput.click());

  fileInput.addEventListener('change', async (e) => {
    const isFirstGrant = !accessGranted;
    const rawFiles = Array.from(e.target.files || []).filter(f => f.type.startsWith('video/'));

    // Dedupe in case the same folder (or an overlapping one) gets picked twice —
    // name + size + last-modified is a good enough fingerprint for local files.
    const newFiles = rawFiles.filter(f => {
      const key = `${f.name}_${f.size}_${f.lastModified}`;
      if (seenKeys.has(key)) return false;
      seenKeys.add(key);
      return true;
    });

    if (!newFiles.length){
      if (isFirstGrant) permDenied.classList.add('show');
      else toast(rawFiles.length ? 'Those videos are already in your library' : 'No videos found in that location');
      fileInput.value = '';
      return;
    }

    if (isFirstGrant){
      permScanning.classList.add('show');
      grantAccessBtn.style.display = 'none';
    } else {
      libSubtitle.textContent = 'Scanning new location…';
    }

    for (const file of newFiles){
      const url = URL.createObjectURL(file);
      const entry = { id: 'lib_' + Date.now() + '_' + Math.random().toString(36).slice(2), file, url, name: file.name, thumb: null, status: 'loading' };
      library.push(entry);
    }
    renderLibraryGrid();

    // Mobile browsers cap concurrent video decoders (often ~4-6) — requesting
    // every thumbnail at once causes most to silently stall until they time out.
    // Process in small batches instead, re-rendering after each so covers fill
    // in progressively rather than all-or-nothing.
    const BATCH_SIZE = 3;
    const pending = library.filter(e => e.status === 'loading');
    for (let i = 0; i < pending.length; i += BATCH_SIZE){
      const batch = pending.slice(i, i + BATCH_SIZE);
      await Promise.all(batch.map(e => generateThumb(e)));
      renderLibraryGrid();
    }

    accessGranted = true;
    permScanning.classList.remove('show');
    permissionGate.style.display = 'none';
    libGrid.classList.add('granted');
    addLocationBtn.style.display = 'flex';
    if (!isFirstGrant) toast(`Added ${newFiles.length} video${newFiles.length === 1 ? '' : 's'}`);
    fileInput.value = '';
  });

  function generateThumb(entry){
    return new Promise(resolve => {
      const v = document.createElement('video');
      v.src = entry.url; v.muted = true; v.playsInline = true; v.preload = 'metadata';
      v.style.position = 'absolute'; v.style.top = '0'; v.style.left = '-99999px';
      v.style.width = '1px'; v.style.height = '1px';
      document.body.appendChild(v); // off-DOM video elements can stall decoding on mobile

      let settled = false;
      const finish = (status) => {
        if (settled) return;
        settled = true;
        entry.status = status; // 'ok' | 'error' | 'timeout'
        v.remove();
        resolve();
      };

      // Hard timeout — if metadata never loads (unsupported codec/container,
      // e.g. many .mkv files on mobile Chrome), fail visibly instead of hanging.
      const timeoutId = setTimeout(() => finish('timeout'), 8000);

      v.addEventListener('error', () => { clearTimeout(timeoutId); finish('error'); });

      v.addEventListener('loadeddata', () => {
        entry.duration = v.duration && isFinite(v.duration) ? v.duration : null;
        try { v.currentTime = Math.min(0.3, (v.duration || 1) / 4); }
        catch(e) { clearTimeout(timeoutId); finish('error'); }
      });

      v.addEventListener('seeked', () => {
        clearTimeout(timeoutId);
        try {
          const c = document.createElement('canvas');
          c.width = v.videoWidth; c.height = v.videoHeight;
          c.getContext('2d').drawImage(v, 0, 0);
          entry.thumb = c.toDataURL('image/jpeg', 0.6);
          finish('ok');
        } catch(e) { finish('error'); }
      });
    });
  }

  // Turns a raw filename into a readable cover title: strips the extension,
  // swaps underscores/dashes for spaces, and trims junk whitespace.
  function formatTitle(filename){
    const noExt = filename.replace(/\.[^/.]+$/, '');
    return noExt.replace(/[_\-]+/g, ' ').replace(/\s+/g, ' ').trim() || filename;
  }

  // Sorted alphabetically by cleaned title, case-insensitive, on every render —
  // this is the single source of truth for list order shown to the user.
  function sortedLibrary(){
    return [...library].sort((a, b) =>
      formatTitle(a.name).localeCompare(formatTitle(b.name), undefined, { sensitivity:'base', numeric:true })
    );
  }

  function renderLibraryGrid(){
    const items = sortedLibrary();
    libSubtitle.textContent = items.length
      ? `${items.length} video${items.length === 1 ? '' : 's'} found · A–Z`
      : 'Access not yet granted';

    libGrid.innerHTML = '';
    items.forEach(entry => {
      const card = document.createElement('div');
      card.className = 'lib-card' + (entry.id === activeLibraryId ? ' playing' : '');
      const title = formatTitle(entry.name);
      const durationBadge = entry.duration ? `<div class="lib-duration">${fmtTime(entry.duration)}</div>` : '';
      if (entry.status === 'ok'){
        card.innerHTML = `<div class="lib-thumb-wrap"><img class="lib-thumb" src="${entry.thumb}">${durationBadge}</div><div class="lib-name">${title}</div>`;
      } else if (entry.status === 'error' || entry.status === 'timeout'){
        const msg = entry.status === 'timeout' ? 'Preview timed out' : 'Can\'t preview this format';
        card.innerHTML = `<div class="lib-thumb-wrap"><div class="lib-thumb" style="display:flex;flex-direction:column;align-items:center;justify-content:center;color:var(--muted);font-size:11px;gap:6px;padding:0 10px;text-align:center;">⚠ ${msg}<span style="color:var(--amber);">Tap to try playing anyway</span></div></div><div class="lib-name">${title}</div>`;
      } else {
        card.innerHTML = `<div class="lib-thumb-wrap"><div class="lib-thumb" style="display:flex;align-items:center;justify-content:center;color:var(--muted);font-size:11px;">Loading…</div></div><div class="lib-name">${title}</div>`;
      }
      card.addEventListener('click', () => selectLibraryVideo(entry));
      libGrid.appendChild(card);
    });
  }

  // Tapping a video plays it immediately and switches straight into the watch screen.
  function selectLibraryVideo(entry){
    if (isRecording) stopCapture(); // never leave a capture dangling on a source swap
    activeLibraryId = entry.id;
    sourceVideo.src = entry.url;
    sourceVideo.play().catch(() => {});
    nowPlaying.textContent = formatTitle(entry.name);
    showScreen('watch');
  }

  backToLibraryBtn.addEventListener('click', () => showScreen('library'));

  sourceVideo.addEventListener('error', () => {
    toast('This video format isn\'t supported by the browser preview');
  });

  renderLibraryGrid();

  // ---------- TAB NAVIGATION ----------
  function showScreen(name){
    document.querySelectorAll('.screen').forEach(s => s.classList.remove('active'));
    const screenId = name === 'library' ? 'libraryScreen' : (name === 'watch' ? 'watchScreen' : 'clipsScreen');
    document.getElementById(screenId).classList.add('active');
    document.querySelectorAll('.tab').forEach(t => t.classList.toggle('active', t.dataset.tab === name || (name === 'watch' && t.dataset.tab === 'library')));
    if (name !== 'watch' && !sourceVideo.paused) sourceVideo.pause();
    applyOrientation();
  }
  document.querySelectorAll('.tab').forEach(t => t.addEventListener('click', () => showScreen(t.dataset.tab)));

  // ---------- AUTO-ROTATE / IMMERSIVE LANDSCAPE PLAYER ----------
  // Browsers auto-rotate pages by default whenever the device's own auto-rotate
  // setting is on — that part isn't something a webpage can force. What we control
  // is how the layout responds once it does rotate: here, turning landscape into a
  // fullscreen player instead of staying boxed inside the portrait phone frame.
  const phoneEl = document.getElementById('phone');
  const orientationQuery = window.matchMedia('(orientation: landscape)');

  function applyOrientation(){
    const isLandscape = orientationQuery.matches;
    const onWatchScreen = document.getElementById('watchScreen').classList.contains('active');
    phoneEl.classList.toggle('landscape-player', isLandscape && onWatchScreen);
  }
  orientationQuery.addEventListener('change', applyOrientation);
  window.addEventListener('resize', applyOrientation);

  // ---------- CLIPS GRID ----------
  const clipGrid = document.getElementById('clipGrid');
  function renderClipGrid(){
    document.getElementById('clipCount').textContent = clips.length;
    document.getElementById('clipCount2').textContent = clips.length;
    document.getElementById('clipCount2b').textContent = clips.length;
    if (!clips.length){
      clipGrid.innerHTML = '<div class="empty-state">No clips yet — tap the record button while watching to save a moment.</div>';
      return;
    }
    clipGrid.innerHTML = '';
    clips.forEach(clip => {
      const card = document.createElement('div');
      card.className = 'clip-card';
      card.innerHTML = `
        <img class="clip-thumb" src="${clip.thumb}">
        <div class="clip-del" data-id="${clip.id}">✕</div>
        <div class="clip-meta"><div class="dur">${fmtTime(clip.duration)}</div></div>
      `;
      card.addEventListener('click', (e) => {
        if (e.target.classList.contains('clip-del')) return;
        openEditor(clip);
      });
      card.querySelector('.clip-del').addEventListener('click', (e) => {
        e.stopPropagation();
        clips = clips.filter(c => c.id !== clip.id);
        URL.revokeObjectURL(clip.url);
        renderClipGrid();
      });
      clipGrid.appendChild(card);
    });
  }

  // ================= EDITOR =================
  const editorPane = document.getElementById('editorPane');
  const editVideo = document.getElementById('editVideo');
  const editCanvas = document.getElementById('editCanvas');
  const ectx = editCanvas.getContext('2d');
  let currentClip = null;
  let editState, editRaf;

  function defaultEditState(){
    return { ratio:'original', scale:1, offsetX:0, offsetY:0, fx:'none', vignette:0, texts:[] };
  }

  function openEditor(clip){
    currentClip = clip;
    editState = defaultEditState();
    editVideo.src = clip.url;
    editVideo.loop = true;
    editVideo.muted = false;
    editVideo.volume = 0.4;
    editorPane.classList.add('active');
    resetControlsUI();
    editVideo.play();
    if (editRaf) cancelAnimationFrame(editRaf);
    editVideo.addEventListener('loadedmetadata', sizeCanvasForRatio, { once:true });
    editDrawLoop();
  }

  function closeEditor(){
    editVideo.pause();
    if (editRaf) cancelAnimationFrame(editRaf);
    editorPane.classList.remove('active');
    document.getElementById('downloadRow').classList.remove('active');
  }
  document.getElementById('closeEditor').addEventListener('click', closeEditor);

  function resetControlsUI(){
    document.querySelectorAll('[data-ratio]').forEach(c => c.classList.toggle('active', c.dataset.ratio === 'original'));
    document.querySelectorAll('[data-fx]').forEach(c => c.classList.toggle('active', c.dataset.fx === 'none'));
    document.getElementById('zoomSlider').value = 1;
    document.getElementById('vignetteSlider').value = 0;
    document.getElementById('textLayerList').innerHTML = '';
    document.getElementById('downloadRow').classList.remove('active');
  }

  function ratioValue(r){
    return { '9:16': 9/16, '1:1': 1, '16:9': 16/9 }[r];
  }

  function sizeCanvasForRatio(){
    const vw = editVideo.videoWidth, vh = editVideo.videoHeight;
    let targetRatio = editState.ratio === 'original' ? vw/vh : ratioValue(editState.ratio);
    const outH = 640;
    editCanvas.width = Math.round(outH * targetRatio);
    editCanvas.height = outH;
  }

  function computeSourceRect(vw, vh, targetRatio, scale, offsetX, offsetY){
    let cw, ch;
    if (vw/vh > targetRatio){ ch = vh; cw = vh*targetRatio; } else { cw = vw; ch = cw/targetRatio; }
    cw /= scale; ch /= scale;
    let cx = (vw-cw)/2 + offsetX;
    let cy = (vh-ch)/2 + offsetY;
    cx = Math.max(0, Math.min(vw-cw, cx));
    cy = Math.max(0, Math.min(vh-ch, cy));
    return { sx:cx, sy:cy, sw:cw, sh:ch };
  }

  const FX_FILTERS = {
    none: '',
    mono: 'grayscale(1) contrast(1.08)',
    warm: 'sepia(0.35) saturate(1.4) contrast(1.05)',
    noir: 'grayscale(1) contrast(1.35) brightness(0.85)'
  };

  let lastTextPositions = []; // for drag hit-testing

  function drawEditFrame(){
    if (!editVideo.videoWidth) return;
    const vw = editVideo.videoWidth, vh = editVideo.videoHeight;
    const targetRatio = editState.ratio === 'original' ? vw/vh : ratioValue(editState.ratio);
    const { sx, sy, sw, sh } = computeSourceRect(vw, vh, targetRatio, editState.scale, editState.offsetX, editState.offsetY);

    ectx.save();
    ectx.filter = FX_FILTERS[editState.fx] || '';
    ectx.drawImage(editVideo, sx, sy, sw, sh, 0, 0, editCanvas.width, editCanvas.height);
    ectx.restore();

    if (editState.vignette > 0){
      const g = ectx.createRadialGradient(
        editCanvas.width/2, editCanvas.height/2, editCanvas.height*0.35,
        editCanvas.width/2, editCanvas.height/2, editCanvas.height*0.75
      );
      g.addColorStop(0, 'rgba(0,0,0,0)');
      g.addColorStop(1, `rgba(0,0,0,${editState.vignette})`);
      ectx.fillStyle = g;
      ectx.fillRect(0,0,editCanvas.width, editCanvas.height);
    }

    lastTextPositions = [];
    editState.texts.forEach(t => {
      const x = t.xf * editCanvas.width, y = t.yf * editCanvas.height;
      ectx.font = '600 26px Inter, sans-serif';
      ectx.textAlign = 'center';
      ectx.lineWidth = 4;
      ectx.strokeStyle = 'rgba(0,0,0,0.65)';
      ectx.fillStyle = '#fff';
      ectx.strokeText(t.text, x, y);
      ectx.fillText(t.text, x, y);
      const w = ectx.measureText(t.text).width;
      lastTextPositions.push({ id:t.id, x, y, w, h:30 });
    });
  }

  function editDrawLoop(){
    drawEditFrame();
    editRaf = requestAnimationFrame(editDrawLoop);
  }

  // ratio chips
  document.querySelectorAll('[data-ratio]').forEach(chip => {
    chip.addEventListener('click', () => {
      document.querySelectorAll('[data-ratio]').forEach(c => c.classList.remove('active'));
      chip.classList.add('active');
      editState.ratio = chip.dataset.ratio;
      editState.offsetX = 0; editState.offsetY = 0;
      sizeCanvasForRatio();
    });
  });

  // fx chips
  document.querySelectorAll('[data-fx]').forEach(chip => {
    chip.addEventListener('click', () => {
      document.querySelectorAll('[data-fx]').forEach(c => c.classList.remove('active'));
      chip.classList.add('active');
      editState.fx = chip.dataset.fx;
    });
  });

  document.getElementById('zoomSlider').addEventListener('input', e => {
    editState.scale = parseFloat(e.target.value);
  });
  document.getElementById('vignetteSlider').addEventListener('input', e => {
    editState.vignette = parseFloat(e.target.value);
  });

  // control tab switching
  document.querySelectorAll('.ctrl-tab').forEach(tab => {
    tab.addEventListener('click', () => {
      document.querySelectorAll('.ctrl-tab').forEach(t => t.classList.remove('active'));
      document.querySelectorAll('.ctrl-panel').forEach(p => p.classList.remove('active'));
      tab.classList.add('active');
      document.querySelector(`[data-panel="${tab.dataset.ctrl}"]`).classList.add('active');
    });
  });

  // text add
  document.getElementById('addTextBtn').addEventListener('click', addTextLayer);
  document.getElementById('textInput').addEventListener('keydown', e => { if (e.key === 'Enter') addTextLayer(); });
  function addTextLayer(){
    const input = document.getElementById('textInput');
    const val = input.value.trim();
    if (!val) return;
    const layer = { id:'t'+Date.now(), text:val, xf:0.5, yf:0.5 };
    editState.texts.push(layer);
    input.value = '';
    renderTextList();
  }
  function renderTextList(){
    const list = document.getElementById('textLayerList');
    list.innerHTML = '';
    editState.texts.forEach(t => {
      const row = document.createElement('div');
      row.className = 'text-layer-item';
      row.innerHTML = `<div>${t.text}<span>drag on frame to move</span></div><button data-id="${t.id}">✕</button>`;
      row.querySelector('button').addEventListener('click', () => {
        editState.texts = editState.texts.filter(x => x.id !== t.id);
        renderTextList();
      });
      list.appendChild(row);
    });
  }

  // drag to pan (zoom) or move text
  let dragMode = null, dragTextId = null, dragStart = null;
  editCanvas.addEventListener('pointerdown', e => {
    const rect = editCanvas.getBoundingClientRect();
    const scaleX = editCanvas.width / rect.width, scaleY = editCanvas.height / rect.height;
    const px = (e.clientX - rect.left) * scaleX, py = (e.clientY - rect.top) * scaleY;
    const hit = lastTextPositions.find(p => Math.abs(px - p.x) < p.w/2 + 20 && Math.abs(py - p.y) < 30);
    if (hit){
      dragMode = 'text'; dragTextId = hit.id;
    } else if (editState.scale > 1){
      dragMode = 'pan'; dragStart = { x:e.clientX, y:e.clientY, ox:editState.offsetX, oy:editState.offsetY };
    }
  });
  editCanvas.addEventListener('pointermove', e => {
    if (dragMode === 'text'){
      const rect = editCanvas.getBoundingClientRect();
      const scaleX = editCanvas.width / rect.width, scaleY = editCanvas.height / rect.height;
      const px = (e.clientX - rect.left) * scaleX, py = (e.clientY - rect.top) * scaleY;
      const t = editState.texts.find(t => t.id === dragTextId);
      if (t){ t.xf = Math.min(1, Math.max(0, px / editCanvas.width)); t.yf = Math.min(1, Math.max(0, py / editCanvas.height)); }
    } else if (dragMode === 'pan'){
      const dx = (e.clientX - dragStart.x) * 1.5, dy = (e.clientY - dragStart.y) * 1.5;
      editState.offsetX = dragStart.ox - dx;
      editState.offsetY = dragStart.oy - dy;
    }
  });
  window.addEventListener('pointerup', () => { dragMode = null; dragTextId = null; });

  // ---------- EXPORT ----------
  document.getElementById('exportBtn').addEventListener('click', exportClip);

  function exportClip(){
    const progress = document.getElementById('exportProgress');
    const progFill = document.getElementById('progFill');
    progress.classList.add('active');
    document.getElementById('downloadRow').classList.remove('active');

    editVideo.pause();
    editVideo.currentTime = 0;
    editVideo.loop = false;

    const exportCanvas = document.createElement('canvas');
    exportCanvas.width = editCanvas.width;
    exportCanvas.height = editCanvas.height;
    exportCanvas.style.position = 'absolute';
    exportCanvas.style.top = '0';
    exportCanvas.style.left = '-99999px';
    document.body.appendChild(exportCanvas); // must be in the live DOM or captureStream can freeze on a single frame
    const xctx = exportCanvas.getContext('2d');

    const stream = exportCanvas.captureStream(30);
    try {
      const vs = editVideo.captureStream ? editVideo.captureStream() : editVideo.mozCaptureStream();
      vs.getAudioTracks().forEach(t => stream.addTrack(t));
    } catch(e){ console.warn('Audio unavailable for export', e); }

    let mimeType = 'video/webm;codecs=vp9,opus';
    if (!MediaRecorder.isTypeSupported(mimeType)) mimeType = 'video/webm';
    const rec = new MediaRecorder(stream, { mimeType });
    const chunks = [];
    rec.ondataavailable = e => { if (e.data.size > 0) chunks.push(e.data); };
    rec.onstop = () => {
      progress.classList.remove('active');
      const blob = new Blob(chunks, { type:'video/webm' });
      const filename = `kc-player-${Date.now()}.webm`;
      const file = new File([blob], filename, { type:'video/webm' });
      const url = URL.createObjectURL(blob);

      const saveBtn = document.getElementById('saveShareBtn');
      const link = document.getElementById('downloadLink');
      link.href = url;
      link.download = filename;

      // Prefer the native share sheet — it hands the file straight to Save to Files /
      // Photos and sidesteps Android's download manager, which can silently "pause"
      // blob-based video downloads (no Content-Length, or battery/data-saver throttling).
      const canShareFile = navigator.canShare && navigator.canShare({ files: [file] });
      if (canShareFile){
        saveBtn.style.display = 'block';
        link.style.display = 'none';
        saveBtn.onclick = async () => {
          try {
            await navigator.share({ files: [file], title: filename });
          } catch(err){
            if (err.name !== 'AbortError') toast('Couldn\'t open the share sheet — try the download link instead');
          }
        };
      } else {
        saveBtn.style.display = 'none';
        link.style.display = 'block';
      }

      document.getElementById('downloadRow').classList.add('active');
      editVideo.loop = true;
      editVideo.play();
      exportCanvas.remove();
      toast('Export ready');
    };

    let raf;
    function renderExportFrame(){
      if (editVideo.paused || editVideo.ended) return;
      const vw = editVideo.videoWidth, vh = editVideo.videoHeight;
      const targetRatio = editState.ratio === 'original' ? vw/vh : ratioValue(editState.ratio);
      const { sx, sy, sw, sh } = computeSourceRect(vw, vh, targetRatio, editState.scale, editState.offsetX, editState.offsetY);
      xctx.save();
      xctx.filter = FX_FILTERS[editState.fx] || '';
      xctx.drawImage(editVideo, sx, sy, sw, sh, 0, 0, exportCanvas.width, exportCanvas.height);
      xctx.restore();
      if (editState.vignette > 0){
        const g = xctx.createRadialGradient(
          exportCanvas.width/2, exportCanvas.height/2, exportCanvas.height*0.35,
          exportCanvas.width/2, exportCanvas.height/2, exportCanvas.height*0.75
        );
        g.addColorStop(0, 'rgba(0,0,0,0)');
        g.addColorStop(1, `rgba(0,0,0,${editState.vignette})`);
        xctx.fillStyle = g;
        xctx.fillRect(0,0,exportCanvas.width, exportCanvas.height);
      }
      editState.texts.forEach(t => {
        const x = t.xf * exportCanvas.width, y = t.yf * exportCanvas.height;
        xctx.font = '600 26px Inter, sans-serif';
        xctx.textAlign = 'center';
        xctx.lineWidth = 4;
        xctx.strokeStyle = 'rgba(0,0,0,0.65)';
        xctx.fillStyle = '#fff';
        xctx.strokeText(t.text, x, y);
        xctx.fillText(t.text, x, y);
      });
      progFill.style.width = Math.min(100, (editVideo.currentTime / editVideo.duration) * 100) + '%';
      raf = requestAnimationFrame(renderExportFrame);
    }

    editVideo.addEventListener('ended', () => { cancelAnimationFrame(raf); rec.stop(); }, { once:true });
    rec.start();
    editVideo.play();
    renderExportFrame();
  }

})();
</script>
<script>
  if ('serviceWorker' in navigator) {
    window.addEventListener('load', () => {
      navigator.serviceWorker.register('service-worker.js').catch(err => {
        console.warn('Service worker registration failed (offline support won\'t be available):', err);
      });
    });
  }
</script>
</body>
</html>
